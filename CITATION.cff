    orcid: "https://orcid.org/0000-0001-5460-5425"
  - given-names: Satyvir
    family-names: Singh
    affiliation: RWTH Aachen University
    orcid: "https://orcid.org/0000-0001-6669-5296"
keywords:
  - "Julia"
  - "finite element method"
  - "Navier-Stokes-Fourier equations"
  - "natural convection"
  - "generalized material laws"
  - "Gridap.jl"
repository-code: "https://github.com/lamBOOO/GeMotion.jl"
